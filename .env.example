# =============================================================================
# Django Settings - Backend
# =============================================================================

# SECURITY WARNING: keep the secret key used in production secret!
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-base64-32

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=1

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Public, externally-reachable origin used to build absolute links embedded in
# artifacts that leave the server (e.g. QR codes scanned by phones). Leave empty
# in dev to fall back to the request origin. In production set to the public
# origin, e.g. https://app.varasto.example — otherwise scanned QR codes point at
# the internal Docker host and lead nowhere.
PUBLIC_BASE_URL=

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite (default for development)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/portable_inventory

# =============================================================================
# JWT Token Settings
# =============================================================================

# Access token lifetime in minutes (default: 1440 = 1 day)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=1440

# Refresh token lifetime in minutes (default: 10080 = 7 days)
JWT_REFRESH_TOKEN_LIFETIME_MINUTES=10080

# =============================================================================
# Frontend Configuration
# =============================================================================

# API base URL for frontend
VITE_API_URL=http://localhost:8000

# =============================================================================
# Optional: Email Configuration (for notifications)
# =============================================================================

# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-specific-password

# =============================================================================
# Optional: Cloud Storage (for media files)
# =============================================================================

# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
