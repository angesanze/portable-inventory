# =============================================================================
# Django Settings - Backend
# =============================================================================

# SECURITY WARNING: keep the secret key used in production secret!
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-base64-32

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=1

# Allowed hosts (SPACE-separated — settings.py splits on whitespace).
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1]

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Public, externally-reachable origin used to build absolute links embedded in
# artifacts that leave the server (e.g. QR codes scanned by phones). Leave empty
# in dev to fall back to the request origin. In production set to the public
# origin, e.g. https://app.varasto.example — otherwise scanned QR codes point at
# the internal Docker host and lead nowhere.
PUBLIC_BASE_URL=

# Origin of the React SPA. Used to build /go/<code>/ QR redirects so a scanned
# code lands on the frontend /widget route (not the backend). Defaults to
# http://localhost:5173 when unset.
FRONTEND_BASE_URL=http://localhost:5173

# NOTE: JWT access/refresh token lifetimes are fixed in settings.py
# (SIMPLE_JWT: 15 minutes access / 7 days refresh) and are NOT configurable via
# env. Change them in config/settings.py if needed.

# Force HTTPS redirects in production (only consulted when DEBUG=0).
# SECURE_SSL_REDIRECT=True

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite (default for development)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/portable_inventory

# =============================================================================
# Frontend Configuration
# =============================================================================

# Base URL the SPA uses for API calls (Vite reads VITE_* at build time).
# In the docker dev stack the Vite dev server proxies /api, /admin, /static and
# /go to the backend, so this can stay same-origin. For non-docker local dev,
# point it directly at the backend:
VITE_API_URL=http://localhost:8000

# =============================================================================
# Optional: Email Configuration (active notifications)
# =============================================================================

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-specific-password
# DEFAULT_FROM_EMAIL=notifications@portable-inventory.local
