<div>
  <div
    class="pi-surface-dark min-h-screen p-4 pb-20"
    data-testid="panel-work-order"
    style="font-family: var(--pi-font, system-ui);"
  >
    <div
      class="max-w-md mx-auto space-y-6"
    >
      <div
        class="flex items-center justify-between p-4 rounded-2xl backdrop-blur-md"
        style="background-color: color-mix(in srgb, var(--pi-primary, #3b82f6) 20%, transparent); border: 1px solid color-mix(in srgb, var(--pi-primary, #3b82f6) 30%, transparent);"
      >
        <div
          class="flex items-center gap-3"
        >
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center shadow-lg"
            style="background-color: var(--pi-primary, #3b82f6);"
          >
            <svg
              aria-hidden="true"
              class="lucide lucide-package"
              fill="none"
              height="20"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              style="color: var(--pi-text);"
              viewBox="0 0 24 24"
              width="20"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"
              />
              <path
                d="M12 22V12"
              />
              <polyline
                points="3.29 7 12 12 20.71 7"
              />
              <path
                d="m7.5 4.27 9 5.15"
              />
            </svg>
          </div>
          <div>
            <h1
              class="text-base font-bold leading-none"
            >
              Test Batch Product
            </h1>
            <p
              class="text-[10px] uppercase tracking-widest mt-1 font-bold"
              style="color: var(--pi-primary, #3b82f6);"
            >
              Batch Management Console
            </p>
          </div>
        </div>
      </div>
      <div
        class="pi-card-dark rounded-3xl overflow-hidden shadow-2xl backdrop-blur-sm"
        style="background-color: var(--pi-surface);"
      >
        <div
          class="p-5"
          style="border-bottom: 1px solid var(--pi-border); background-color: color-mix(in srgb, var(--pi-primary) 6%, transparent);"
        >
          <div
            class="flex justify-between items-start"
          >
            <div
              class="space-y-1"
            >
              <h3
                class="text-base font-bold tracking-tight"
                style="color: var(--pi-text);"
              >
                Model A
              </h3>
              <div
                class="flex items-center gap-2"
              >
                <span
                  class="text-xs font-mono px-2 py-0.5 rounded-md"
                  style="color: var(--pi-muted, #64748b); background-color: var(--pi-surface); border: 1px solid var(--pi-border);"
                >
                  MOD-A
                </span>
                <span
                  class="text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-tighter"
                  style="background-color: color-mix(in srgb, var(--pi-success, #10b981) 10%, transparent); color: var(--pi-success, #10b981); border: 1px solid color-mix(in srgb, var(--pi-success, #10b981) 20%, transparent);"
                >
                  BULK
                </span>
              </div>
            </div>
            <div
              class="text-right"
            >
              <div
                class="text-2xl font-black leading-none"
                style="color: var(--pi-primary, #3b82f6);"
              >
                50
              </div>
              <div
                class="text-[10px] font-bold uppercase mt-1"
                style="color: var(--pi-muted, #64748b);"
              >
                Total Stock
              </div>
            </div>
          </div>
        </div>
        <div
          class="p-5 space-y-4"
        >
          <div
            class="space-y-4"
          >
            <div
              class="space-y-2"
            >
              <label
                class="text-[10px] font-bold uppercase tracking-widest pl-1"
                style="color: var(--pi-muted, #64748b);"
              >
                Active Lots / Batches
              </label>
              <div
                class="grid gap-2"
              >
                <div
                  class="text-center py-6 text-xs italic rounded-2xl border border-dashed"
                  style="color: var(--pi-muted, #64748b); background-color: var(--pi-surface); border-color: var(--pi-border);"
                >
                  No active lots for this model
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div
      class="fixed bottom-0 left-0 right-0 p-4 transition-all duration-300 z-50"
    >
      <div
        class="max-w-md mx-auto"
      />
    </div>
  </div>
</div>
`;

