exports[`Panel theming — CSS custom property classes > DOM snapshots — default + branded theme > branded theme (--pi-primary: #ff4500) > TrackerPanel snapshot 1`] = `
<div>
  <div
    class="space-y-4"
    data-testid="panel-tracker-form"
  >
    <div
      class="grid gap-3"
    >
      <div>
        <label
          class="pi-label"
        >
          Item
        </label>
        <div
          class="flex flex-col gap-1.5 "
        >
          <button
            aria-expanded="false"
            aria-haspopup="listbox"
            class="w-full bg-zinc-900 border border-white/[0.06] rounded-lg text-sm text-zinc-50 placeholder:text-zinc-500 transition-all duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500/30 focus-visible:border-indigo-500/50 disabled:opacity-50 disabled:cursor-not-allowed h-9 px-3 flex items-center justify-between text-left cursor-pointer"
            role="combobox"
            style="background-color: var(--pi-input-bg, #18181b); border-color: var(--pi-border, rgba(255,255,255,0.06)); color: var(--pi-text, #fafafa);"
            type="button"
          >
            <span
              class="block truncate"
              style="color: var(--pi-muted, #71717a);"
            >
              Select item...
            </span>
            <svg
              aria-hidden="true"
              class="lucide lucide-chevron-down shrink-0 transition-transform duration-150"
              fill="none"
              height="16"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              style="color: var(--pi-muted, #71717a);"
              viewBox="0 0 24 24"
              width="16"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="m6 9 6 6 6-6"
              />
            </svg>
          </button>
        </div>
        <p
          class="text-xs mt-1"
          style="color: var(--pi-muted, #64748b);"
        >
          Items loaded from product inventory
        </p>
      </div>
      <div>
        <label
          class="pi-label"
        >
          Status
        </label>
        <div
          class="flex flex-wrap gap-2"
        >
          <button
            aria-pressed="false"
            class="pi-status-btn inline-flex items-center gap-1.5 px-3 py-2 rounded-md text-sm font-semibold transition disabled:opacity-50 disabled:cursor-not-allowed"
            style="background-color: var(--pi-input-bg, #27272a); color: var(--pi-text, #f4f4f5); box-shadow: 0 0 0 1px var(--pi-border, #3f3f46);"
            type="button"
          >
            Active
          </button>
          <button
            aria-pressed="false"
            class="pi-status-btn inline-flex items-center gap-1.5 px-3 py-2 rounded-md text-sm font-semibold transition disabled:opacity-50 disabled:cursor-not-allowed"
            style="background-color: var(--pi-input-bg, #27272a); color: var(--pi-text, #f4f4f5); box-shadow: 0 0 0 1px var(--pi-border, #3f3f46);"
            type="button"
          >
            Repair
          </button>
        </div>
      </div>
      <div>
        <label
          class="pi-label"
        >
          Notes
        </label>
        <input
          class="pi-input"
          placeholder="Optional notes..."
          type="text"
          value=""
        />
      </div>
    </div>
    <button
      class="w-full pi-btn-accent py-3 disabled:opacity-50 transition-colors"
      disabled=""
    >
      UPDATE STATUS
    </button>
  </div>
</div>
`;

