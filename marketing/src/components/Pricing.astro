---
import { plans } from "../data/pricing";
---

<section id="pricing" class="mx-auto max-w-5xl px-6 py-20">
  <div class="mb-12 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-slate-900">Prezzo</h2>
    <p class="mt-3 text-slate-600">Oggi Varasto è gratuito. Nessuna sorpresa.</p>
  </div>
  <div
    class:list={[
      "mx-auto grid gap-6",
      plans.length > 1 ? "sm:grid-cols-2 lg:grid-cols-3" : "max-w-md",
    ]}
  >
    {
      plans.map((plan) => (
        <div
          class:list={[
            "flex flex-col rounded-2xl border p-8",
            plan.highlight ? "border-indigo-600 ring-1 ring-indigo-600" : "border-slate-200",
          ]}
        >
          <h3 class="font-semibold text-slate-900">{plan.name}</h3>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-slate-900">{plan.price}</span>
            {plan.period && <span class="text-slate-500">{plan.period}</span>}
          </div>
          {plan.tagline && <p class="mt-2 text-sm text-slate-600">{plan.tagline}</p>}
          <ul class="mt-6 space-y-3 text-sm text-slate-600">
            {plan.features.map((feat) => (
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-none text-indigo-600" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0Z"
                    clip-rule="evenodd"
                  />
                </svg>
                <span>{feat}</span>
              </li>
            ))}
          </ul>
          <a
            href={plan.cta.href}
            class:list={[
              "mt-8 block rounded-lg px-4 py-3 text-center font-medium transition",
              plan.highlight
                ? "bg-indigo-600 text-white hover:bg-indigo-700"
                : "border border-slate-200 text-slate-700 hover:bg-slate-50",
            ]}
          >
            {plan.cta.label}
          </a>
        </div>
      ))
    }
  </div>
</section>
