---
import { capabilities } from "../data/capabilities";
---

<section id="funzioni" class="border-y border-white/[0.06] bg-zinc-900/30">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold text-indigo-400">Tutto quello che serve</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-zinc-50 sm:text-4xl">
        Un gestionale completo, pensato per il magazzino vero
      </h2>
      <p class="mt-4 text-zinc-400">
        Dalla tracciabilità di lotti e matricole agli ordini, dalla multi-azienda al widget
        incorporabile: ecco tutto quello che puoi fare, già oggi.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        capabilities.map((c) => (
          <div class="rounded-xl border border-white/[0.06] bg-zinc-950/40 p-6">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400 [&>svg]:h-5 [&>svg]:w-5">
              <Fragment set:html={c.icon} />
            </div>
            <h3 class="font-semibold text-zinc-100">{c.title}</h3>
            <p class="mt-1 text-sm text-zinc-500">{c.tagline}</p>
            <ul class="mt-4 space-y-2">
              {c.items.map((it) => (
                <li class="flex gap-2.5 text-sm text-zinc-400">
                  <svg
                    class="mt-1 h-3.5 w-3.5 flex-none text-indigo-500"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
