---
// Mockup fedele della dashboard di Varasto — replica in HTML/CSS del gestionale
// dark reale (token: canvas #09090b, pannelli zinc-900, bordi white/6%, accento
// indigo). Fa da "screenshot" dato che nel repo non esistono catture reali.
const kpis = [
  { label: "Prodotti totali", value: "1.284", tint: "bg-indigo-500/15 text-indigo-400" },
  { label: "Articoli attivi", value: "9.640", tint: "bg-emerald-500/15 text-emerald-400" },
  { label: "Giacenza totale", value: "48.210", tint: "bg-cyan-500/15 text-cyan-400" },
  { label: "Ordini in lavoro", value: "7", tint: "bg-amber-500/15 text-amber-400" },
];

const nav = [
  { g: "Overview", items: [["Dashboard", true]] },
  { g: "Inventory", items: [["Giacenze", false], ["Movimenti", false], ["Restock", false]] },
  { g: "Commerce", items: [["Acquisti", false], ["Vendite", false]] },
];

const movements = [
  { dot: "bg-emerald-500", name: "Cavo HDMI 2m", desc: "Carico · +240", t: "2 min fa" },
  { dot: "bg-orange-500", name: "Vaccino lotto V-88", desc: "Scarico · −12", t: "18 min fa" },
  { dot: "bg-blue-500", name: "Laptop SN-4471", desc: "Trasferimento", t: "1 h fa" },
  { dot: "bg-emerald-500", name: "Vite M4 (sfuso)", desc: "Carico · +5.000", t: "3 h fa" },
];
---

<div
  class="overflow-hidden rounded-xl border border-white/[0.08] bg-zinc-900/80 shadow-2xl shadow-black/60 ring-1 ring-white/[0.04] backdrop-blur"
>
  <!-- window chrome -->
  <div class="flex items-center gap-2 border-b border-white/[0.06] bg-zinc-900 px-4 py-3">
    <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
    <span class="h-3 w-3 rounded-full bg-amber-500/80"></span>
    <span class="h-3 w-3 rounded-full bg-emerald-500/80"></span>
    <div
      class="ml-3 flex items-center gap-1.5 rounded-md bg-zinc-800/70 px-2.5 py-1 text-[11px] text-zinc-500"
    >
      <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        ><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"
        ></path></svg
      >
      app.varasto.rocks
    </div>
  </div>

  <div class="flex min-h-[430px]">
    <!-- sidebar -->
    <aside class="hidden w-56 shrink-0 flex-col border-r border-white/[0.06] bg-zinc-900 p-3 sm:flex">
      <div class="flex items-center gap-2.5 px-2 pb-4">
        <img src="/shed-logo.png" alt="" width="26" height="26" class="rounded-md" />
        <div class="leading-tight">
          <div class="text-[13px] font-bold text-zinc-100">Varasto</div>
          <div class="text-[10px] text-zinc-500">Acme S.r.l.</div>
        </div>
      </div>
      <div
        class="mb-4 flex items-center justify-between rounded-lg bg-zinc-800/60 px-2.5 py-1.5 text-[11px] text-zinc-500"
      >
        <span class="flex items-center gap-1.5">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg
          >
          Cerca…
        </span>
        <kbd class="rounded border border-zinc-700 bg-zinc-800 px-1 text-[9px]">⌘K</kbd>
      </div>
      {
        nav.map((group) => (
          <div class="mb-3">
            <div class="px-2 pb-1 text-[10px] font-medium uppercase tracking-wider text-zinc-600">
              {group.g}
            </div>
            {group.items.map(([label, active]) => (
              <div
                class:list={[
                  "relative flex items-center gap-2.5 rounded-lg px-2.5 py-1.5 text-[13px]",
                  active ? "bg-indigo-500/10 font-medium text-zinc-100" : "text-zinc-400",
                ]}
              >
                {active && (
                  <span class="absolute left-0 top-1/2 h-4 w-0.5 -translate-y-1/2 rounded-full bg-indigo-500" />
                )}
                <span
                  class:list={[
                    "h-1.5 w-1.5 rounded-full",
                    active ? "bg-indigo-400" : "bg-zinc-600",
                  ]}
                />
                {label}
              </div>
            ))}
          </div>
        ))
      }
    </aside>

    <!-- main -->
    <div class="flex-1 space-y-4 p-4 sm:p-5">
      <div>
        <div class="text-lg font-semibold text-zinc-50">Dashboard</div>
        <div class="text-xs text-zinc-500">Panoramica del magazzino</div>
      </div>

      <div class="grid grid-cols-2 gap-3 lg:grid-cols-4">
        {
          kpis.map((k) => (
            <div class="rounded-xl border border-white/[0.06] bg-zinc-900/80 p-3">
              <div
                class:list={[
                  "mb-2 inline-flex h-7 w-7 items-center justify-center rounded-lg",
                  k.tint,
                ]}
              >
                <span class="h-2 w-2 rounded-sm bg-current" />
              </div>
              <div class="text-xl font-semibold text-zinc-50">{k.value}</div>
              <div class="text-[11px] text-zinc-500">{k.label}</div>
            </div>
          ))
        }
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        <div class="rounded-xl border border-white/[0.06] bg-zinc-900/80 p-4 lg:col-span-2">
          <div class="mb-3 flex items-center justify-between">
            <div class="text-[13px] font-semibold text-zinc-200">Movimenti</div>
            <div class="flex gap-0.5 rounded-lg bg-zinc-800/60 p-0.5 text-[10px]">
              <span class="rounded bg-zinc-700 px-2 py-0.5 text-zinc-100">7g</span>
              <span class="px-2 py-0.5 text-zinc-500">30g</span>
              <span class="px-2 py-0.5 text-zinc-500">90g</span>
            </div>
          </div>
          <svg viewBox="0 0 320 120" class="h-[130px] w-full" preserveAspectRatio="none">
            <defs>
              <linearGradient id="area" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#6366f1" stop-opacity="0.25"></stop>
                <stop offset="100%" stop-color="#6366f1" stop-opacity="0"></stop>
              </linearGradient>
            </defs>
            <line x1="0" y1="30" x2="320" y2="30" stroke="rgba(255,255,255,0.04)"></line>
            <line x1="0" y1="60" x2="320" y2="60" stroke="rgba(255,255,255,0.04)"></line>
            <line x1="0" y1="90" x2="320" y2="90" stroke="rgba(255,255,255,0.04)"></line>
            <path
              d="M0,82 L40,58 L80,66 L120,40 L160,52 L200,30 L240,38 L280,20 L320,26 L320,120 L0,120 Z"
              fill="url(#area)"></path>
            <polyline
              points="0,82 40,58 80,66 120,40 160,52 200,30 240,38 280,20 320,26"
              fill="none"
              stroke="#6366f1"
              stroke-width="2"
              stroke-linejoin="round"
              stroke-linecap="round"></polyline>
            <polyline
              points="0,98 40,92 80,98 120,84 160,90 200,82 240,88 280,78 320,84"
              fill="none"
              stroke="#71717a"
              stroke-width="2"
              stroke-linejoin="round"
              stroke-linecap="round"></polyline>
          </svg>
          <div class="mt-2 flex items-center gap-4 text-[10px] text-zinc-500">
            <span class="flex items-center gap-1.5"
              ><span class="h-1.5 w-3 rounded-full bg-indigo-500"></span>Carichi</span
            >
            <span class="flex items-center gap-1.5"
              ><span class="h-1.5 w-3 rounded-full bg-zinc-500"></span>Scarichi</span
            >
          </div>
        </div>

        <div class="rounded-xl border border-white/[0.06] bg-zinc-900/80 p-4">
          <div class="mb-2 text-[13px] font-semibold text-zinc-200">Movimenti recenti</div>
          <div class="divide-y divide-white/[0.04]">
            {
              movements.map((m) => (
                <div class="flex items-center gap-2.5 py-2">
                  <span class:list={["h-1.5 w-1.5 shrink-0 rounded-full", m.dot]} />
                  <div class="min-w-0 flex-1">
                    <div class="truncate text-[12px] font-medium text-zinc-200">{m.name}</div>
                    <div class="truncate text-[11px] text-zinc-500">{m.desc}</div>
                  </div>
                  <div class="shrink-0 text-[10px] text-zinc-600">{m.t}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
