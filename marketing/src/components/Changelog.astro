---
import { changelog } from "../data/changelog";
---

<section id="changelog" class="mx-auto max-w-3xl px-6 py-20 sm:py-24">
  <div class="mb-12 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-zinc-50">Novità</h2>
    <p class="mt-3 text-zinc-400">Cosa è cambiato di recente.</p>
  </div>
  <ol class="relative border-s border-white/[0.08]">
    {
      changelog.map((entry) => (
        <li class="mb-10 ms-6 last:mb-0">
          <span class="absolute -start-1.5 mt-1.5 h-3 w-3 rounded-full border-2 border-zinc-950 bg-indigo-500" />
          <div class="flex items-center gap-3">
            <span class="rounded-md border border-white/[0.06] bg-white/[0.03] px-2 py-0.5 font-mono text-[11px] text-zinc-300">
              v{entry.version}
            </span>
            <time class="text-xs text-zinc-600">{entry.date}</time>
          </div>
          <ul class="mt-3 space-y-1.5 text-sm text-zinc-400">
            {entry.changes.map((c) => (
              <li class="flex gap-2">
                <span class="text-zinc-700">—</span>
                <span>{c}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</section>
