---
import { changelog } from "../data/changelog";
---

<section id="changelog" class="mx-auto max-w-3xl px-6 py-20">
  <div class="mb-12 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-slate-900">Novità</h2>
    <p class="mt-3 text-slate-600">Cosa è cambiato di recente.</p>
  </div>
  <ol class="relative border-s border-slate-200">
    {
      changelog.map((entry) => (
        <li class="mb-10 ms-6 last:mb-0">
          <span class="absolute -start-1.5 mt-1.5 h-3 w-3 rounded-full border-2 border-white bg-indigo-600" />
          <div class="flex items-center gap-3">
            <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">
              v{entry.version}
            </span>
            <time class="text-xs text-slate-400">{entry.date}</time>
          </div>
          <ul class="mt-3 space-y-1 text-sm text-slate-600">
            {entry.changes.map((c) => (
              <li class="flex gap-2">
                <span class="text-slate-300">—</span>
                <span>{c}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</section>
